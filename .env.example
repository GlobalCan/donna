# =============================================================================
# Donna — environment template
# Copy to .env (not committed) and fill in real values for local dev.
# In production on the droplet, secrets are decrypted from sops at startup
# and override anything set here.
#
# IMPORTANT: no inline `# comments` after values. docker-compose's env_file
# parser and pydantic-settings both treat them as part of the value string,
# which breaks pydantic int validation on the Discord snowflake fields.
# Place commentary on its own line ABOVE the value.
# =============================================================================

# --- Core identity ---------------------------------------------------------
# dev | prod
DONNA_ENV=dev
# ./data for local; /data on droplet
DONNA_DATA_DIR=./data
DONNA_LOG_LEVEL=INFO

# --- Container user (prod only; ignored in local dev) ----------------------
# Override container uid:gid to match the host user that owns /etc/bot/age.key
# and /data/donna. Default matches a vanilla harden-droplet.sh-created bot
# user (uid 1001). Only touch these if the droplet's bot uid is different.
DONNA_UID=1001
DONNA_GID=1001

# --- Discord ---------------------------------------------------------------
# Bot token from Discord Developer Portal
DISCORD_BOT_TOKEN=
# Your own Discord user ID (integer snowflake)
DISCORD_ALLOWED_USER_ID=
# Optional: scope slash commands to one guild for faster registration
DISCORD_GUILD_ID=

# --- Anthropic -------------------------------------------------------------
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_FAST=claude-haiku-4-5-20251001
ANTHROPIC_MODEL_STRONG=claude-sonnet-4-6
ANTHROPIC_MODEL_HEAVY=claude-opus-4-6

# --- Tavily (web search) ---------------------------------------------------
TAVILY_API_KEY=

# --- OPENAI (web search) ---------------------------------------------------
OPENAI_API_KEY=OPENAI_KEY
# --- Voyage (embeddings) ---------------------------------------------------
VOYAGE_API_KEY=
VOYAGE_EMBED_MODEL=voyage-3

# --- Concurrency / budgets --------------------------------------------------
DONNA_MAX_CONCURRENT_JOBS=3
# USD thresholds, comma-separated
DONNA_DAILY_BUDGET_ALERTS=5,15,30
DONNA_MAX_TOOL_CALLS_PER_JOB=60
DONNA_COMPACT_EVERY_N=20

# --- Observability (Jaeger / OTLP) -----------------------------------------
# Jaeger all-in-one replaced Phoenix after Phoenix 14.x shipped broken
# upstream. Same OTLP-gRPC port (4317), so the bot/worker exporter code
# didn't move — only the hostname. UI lives at http://localhost:16686
# (port-forward via `ssh -L 16686:localhost:16686 bot@DROPLET`).
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317
OTEL_SERVICE_NAME=donna

# --- Rate limits (fallback caps if the SDK doesn't report them) ------------
DONNA_RATE_HAIKU_RPM=4000
DONNA_RATE_HAIKU_ITPM=400000
DONNA_RATE_HAIKU_OTPM=80000
DONNA_RATE_SONNET_RPM=4000
DONNA_RATE_SONNET_ITPM=400000
DONNA_RATE_SONNET_OTPM=80000
DONNA_RATE_OPUS_RPM=4000
DONNA_RATE_OPUS_ITPM=200000
DONNA_RATE_OPUS_OTPM=40000
